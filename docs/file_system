# pf-fs v1. pflash file system




# boot-block #0
0x00 uint_8     MagicNumber[4] = "pffs"
0x04 uint_8     Version
0x05 uint_32    inodes_start block
0x09 uint_8     number of inodes 2^x blocks

# inod
uint_32 block addresses[4]
uint_32 size in bytes or files
uint_8 flags
    uint_1 is dir
    uint_1 is large

# dnode
uint_8 object_name[30]
uint_16 i-number

#structure
0   boot-block
1-n inodes
 +n blocks

