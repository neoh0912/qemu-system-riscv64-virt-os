device_scanner:
    0x0 scanner: *function
    0x8 next: *device_scanner

void scanner()
    init device
    call device_manager_register_device

device_tree:

0x0 device_type: char[8]
0x8 start: *device
0x10 avail_id: int
0x18 next: *device_tree


device:
0x00 id: int
0x08 device_type: char[8]
0x10 device: *device_object
0x18 parent: *device
0x20 read: *function
0x28 write: *function
0x30 ioctl: *function
0x38 next: *device
0x40 parent_set: bool

device_types

keyboard
    read(device: *device_object, operation: char)
        '\0' = pull event
            dword read(...)
        '\1' = pull up to n events
            void read(...,buffer: dword[n], n: int)
    void write()
            not implemented
    void ioctl()
            not implemented

display
    void read()
        not implemented
    void write(device: *device_object, operation: char)
        '\0' = write buffer
            void write(...,buffer words[])
        's' = write sprite
            void write(...,surface: int32[], x,y,w,h)
                sizeof(sprite)*w by sizeof(sprite)*h
    void ioctl(device: *device_object, operation, char)
        '\0' get resolution
            qword qword ioctl(...)
        '\1' set resolution
            void ioctl(...,x,y)

blkdrive
    void read(device: *device_object, operation: char)
        '\0' = read sector to buffer
            void read(...,sector,buffer)
    void write(device: *device_object, operation: char)
        '\0' = write buffer to sector
            void write(...,sector,buffer)
    void ioctl(device: *device_object, operation: char)
        not implemented
